<mujoco model="ability_hand">
  <compiler angle="radian" meshdir="./" autolimits="true"/>
  <default/>
  <asset>
    <mesh name="wristmesh" file="wristmesh.STL"/>
    <!-- <mesh name="FB_palm_ref" file="FB_palm_ref.STL"/> -->
    <mesh name="palm_hull" file="palm_hull.STL"/>
    <!-- <mesh name="idx-F1" file="idx-F1.STL"/> -->
    <mesh name="idx-F1-hull" file="idx-F1-hull.STL"/>
    <!-- <mesh name="idx-F2" file="idx-F2-Lg.STL"/> -->
    <mesh name="idx-F2-hull" file="idx-F2-Lg-hull.STL"/>
    <!-- <mesh name="thumb-F1" file="thumb-F1.STL"/> -->
    <mesh name="thumb-F1-hull" file="thumb-F1-hull.STL"/>
    <!-- <mesh name="thumb-F2" file="thumb-F2.STL"/> -->
    <mesh name="thumb-F2-hull" file="thumb-F2-hull.STL"/>
  </asset>

  <!--   A red floor for the hand to fall on -->
  <worldbody>
    <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1"/>
    <geom type="plane" size="1 1 0.1" rgba=".9 0 0 1" friction="1 0.005 0.0001"/>
  </worldbody>
  
  <worldbody>
    <body name="base" pos="0 0 0.1" gravcomp="0">
	    <joint name="floating_base" type="free"/>
      <geom name="wrist_mesh" type="mesh" contype="0" conaffinity="0" group="1" mass="0.075" mesh="wristmesh" friction="1 0.005 0.0001"/>
      <geom name="palm_hull" pos="0.0240477 0.00378125 0.0323296" quat="0.0442297 0.00061027 0.999021 2.70192e-05" mass="0.3" type="mesh" mesh="palm_hull"/>
      <body name="index_L1" pos="0.0279216 -0.00927034 0.0958706" quat="-0.714459 -0.129917 0.685906 0.0469401" gravcomp="0">
        <joint name="index_q1" pos="0 0 0" axis="0 0 1" range="0 2.0944" damping="0.1" frictionloss="0.01"/>
        <geom name="index_hull_1" pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244" type="mesh" mass=".008" mesh="idx-F1-hull"/>
        <body name="index_L2" pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244" gravcomp="0">
          <joint name="index_q2" pos="0 0 0" axis="0 0 1" range="0 2.6586" damping="0" frictionloss="0"/>
          <geom name="index_hull_2" pos="0.0091241 0 0" type="mesh" mass=".008" mesh="idx-F2-hull"/>
        </body>
      </body>
      <body name="middle_L1" pos="0.00841718 -0.0115172 0.0990634" quat="-0.698395 -0.103508 0.704562 0.0715738" gravcomp="0">
        <joint name="middle_q1" pos="0 0 0" axis="0 0 1" range="0 2.0944" damping="0.1" frictionloss="0.01"/>
        <geom name="middle_hull_1" pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244" mass=".008" type="mesh" mesh="idx-F1-hull"/>
        <body name="middle_L2" pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244" gravcomp="0">
          <joint name="middle_q2" pos="0 0 0" axis="0 0 1" range="0 2.6586" damping="0" frictionloss="0"/>
          <geom name="middle_hull_2" pos="0.0091241 0 0" type="mesh" mass=".008" mesh="idx-F2-hull"/>
        </body>
      </body>
      <body name="ring_L1" pos="-0.0117529 -0.0103946 0.0967038" quat="-0.681173 -0.0769649 0.721351 0.0986547" gravcomp="0">
        <joint name="ring_q1" pos="0 0 0" axis="0 0 1" range="0 2.0944" damping="0.1" frictionloss="0.01"/>
        <geom name="ring_hull_1" pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244" type="mesh" mass=".008" mesh="idx-F1-hull"/>
        <body name="ring_L2" pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244" gravcomp="0">
          <joint name="ring_q2" pos="0 0 0" axis="0 0 1" range="0 2.6586" damping="0" frictionloss="0"/>
          <geom name="ring_hull_2" pos="0.0091241 0 0" type="mesh" mass=".008" mesh="idx-F2-hull"/>
        </body>
      </body>
      <body name="pinky_L1" pos="-0.0308633 -0.00716283 0.0907346" quat="-0.681748 -0.0544096 0.719226 0.122363" gravcomp="0">
        <joint name="pinky_q1" pos="0 0 0" axis="0 0 1" range="0 2.0944" damping="0.1" frictionloss="0.01"/>
        <geom name="pinky_hull_1" pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244" type="mesh" mass=".008" mesh="idx-F1-hull"/>
        <body name="pinky_L2" pos="0.0384727 0.0032577 0" quat="0.999108 0 0 0.0422244" gravcomp="0">
          <joint name="pinky_q2" pos="0 0 0" axis="0 0 1" range="0 2.6586" damping="0" frictionloss="0"/>
          <geom name="pinky_hull_2" pos="0.0091241 0 0" type="mesh" mass=".008" mesh="idx-F2-hull"/>
        </body>
      </body>
      <body name="thumb_L1" pos="0.0240477 0.00378125 0.0323296" quat="-0.00419696 0.994514 -0.0947972 0.0440301" gravcomp="0">
        <joint name="thumb_q1" pos="0 0 0" axis="0 0 1" range="-2.0944 0" damping="0.1" frictionloss="0.01"/>
        <geom name="thumb_hull_1" pos="0.0278284 0 -0.0147507" quat="-0.608761 0.793353 0 0" type="mesh" mass=".008" mesh="thumb-F1-hull"/>
        <body name="thumb_L2" pos="0.0278284 0 -0.0147507" quat="-0.608761 0.793353 0 0" gravcomp="0">
          <joint name="thumb_q2" pos="0 0 0" axis="0 0 1" range="0 2.0944" damping="0.1" frictionloss="0.01"/>
          <geom name="thumb_hull_2" pos="0.0651867 0.0233402 -0.00393483" quat="3.21978e-07 0.985259 0.171069 5.59046e-08" type="mesh" mass=".008" mesh="thumb-F2-hull"/>
        </body>
      </body>
    </body>
  </worldbody>



  <!-- Note for future reference: it should be possible to implement the 4 bar mechanism using a tendon and a spring (stiffness+springref) in joint 2 of each finger;
  the spring 'tensions' the tendon and the tendon provides the 4th bar constraint. This will also model flexibility of the joint/compliance of the joint to some extent -->
  <actuator>
    <position name="index_actuator" joint="index_q1" ctrllimited="true" ctrlrange="0 2.0944" kp = "2"/>
    <position name="middle_actuator" joint="middle_q1" ctrllimited="true" ctrlrange="0 2.0944" kp = "2"/>
    <position name="ring_actuator" joint="ring_q1" ctrllimited="true" ctrlrange="0 2.0944" kp = "2"/>
    <position name="pinky_actuator" joint="pinky_q1" ctrllimited="true" ctrlrange="0 2.0944" kp = "2"/>
    <position name="thumbrotator_actuator" joint="thumb_q1" ctrllimited="true" ctrlrange="-2.0944 0" kp = "2"/>
    <position name="thumbflexor_actuator" joint="thumb_q2" ctrllimited="true" ctrlrange="0 2.0944" kp = "2"/>
  </actuator>

</mujoco>
